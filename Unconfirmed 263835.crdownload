<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>📔 Personal Diary & Habit Tracker</title>
    <link rel="stylesheet" href="styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <div class="app-container">
        <!-- Sidebar Navigation -->
        <nav class="sidebar">
            <div class="logo">
                <i class="fas fa-book"></i>
                <span>My Diary</span>
            </div>
            <ul class="nav-tabs">
                <li class="nav-item active" data-tab="daily">
                    <i class="fas fa-calendar-day"></i>
                    <span>Daily Entry</span>
                </li>
                <li class="nav-item" data-tab="video">
                    <i class="fas fa-video"></i>
                    <span>Video Diary</span>
                </li>
                <li class="nav-item" data-tab="history">
                    <i class="fas fa-history"></i>
                    <span>History</span>
                </li>
                <li class="nav-item" data-tab="statistics">
                    <i class="fas fa-chart-bar"></i>
                    <span>Statistics</span>
                </li>
                <li class="nav-item" data-tab="notes">
                    <i class="fas fa-sticky-note"></i>
                    <span>Daily Notes</span>
                </li>
            </ul>
            <div class="user-info">
                <div class="current-date-small" id="currentDateSmall"></div>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Daily Entry Tab -->
            <div class="tab-content active" id="daily-tab">
                <header class="page-header">
                    <h1>📅 Daily Habit Tracker</h1>
                    <div class="date-display" id="currentDate"></div>
                </header>

                <div class="habits-container">
                    <!-- Sleep Tracking -->
                    <div class="habit-card">
                        <div class="habit-icon">😴</div>
                        <h3>Sleep</h3>
                        <div class="habit-inputs">
                            <div class="input-group">
                                <label>Hours Slept</label>
                                <input type="number" id="sleepHours" min="0" max="24" step="0.5" placeholder="0">
                            </div>
                            <div class="input-group">
                                <label>Quality</label>
                                <div class="star-rating" id="sleepQuality">
                                    <i class="far fa-star" data-rating="1"></i>
                                    <i class="far fa-star" data-rating="2"></i>
                                    <i class="far fa-star" data-rating="3"></i>
                                    <i class="far fa-star" data-rating="4"></i>
                                    <i class="far fa-star" data-rating="5"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Study Tracking -->
                    <div class="habit-card">
                        <div class="habit-icon">📚</div>
                        <h3>Study</h3>
                        <div class="habit-inputs">
                            <div class="input-group">
                                <label>Hours</label>
                                <input type="number" id="studyHours" min="0" max="24" step="0.5" placeholder="0">
                            </div>
                            <div class="input-group">
                                <label>Subject</label>
                                <input type="text" id="studySubject" placeholder="What did you study?">
                            </div>
                            <div class="input-group">
                                <label>Focus Level</label>
                                <select id="studyFocus">
                                    <option value="">Select</option>
                                    <option value="low">Low 🟡</option>
                                    <option value="medium">Medium 🟠</option>
                                    <option value="high">High 🔴</option>
                                    <option value="excellent">Excellent 🟢</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Exercise Tracking -->
                    <div class="habit-card">
                        <div class="habit-icon">🏃</div>
                        <h3>Exercise</h3>
                        <div class="habit-inputs">
                            <div class="input-group">
                                <label>Minutes</label>
                                <input type="number" id="exerciseMinutes" min="0" placeholder="0">
                            </div>
                            <div class="input-group">
                                <label>Type</label>
                                <select id="exerciseType">
                                    <option value="">Select Type</option>
                                    <option value="running">🏃 Running</option>
                                    <option value="walking">🚶 Walking</option>
                                    <option value="gym">💪 Gym</option>
                                    <option value="yoga">🧘 Yoga</option>
                                    <option value="swimming">🏊 Swimming</option>
                                    <option value="cycling">🚴 Cycling</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Meditation -->
                    <div class="habit-card">
                        <div class="habit-icon">🧘</div>
                        <h3>Meditation</h3>
                        <div class="habit-inputs">
                            <div class="input-group">
                                <label>Minutes</label>
                                <input type="number" id="meditationMinutes" min="0" placeholder="0">
                            </div>
                        </div>
                    </div>

                    <!-- Water Intake -->
                    <div class="habit-card">
                        <div class="habit-icon">💧</div>
                        <h3>Water Intake</h3>
                        <div class="habit-inputs">
                            <div class="input-group">
                                <label>Glasses (250ml)</label>
                                <div class="water-counter">
                                    <button class="water-btn minus">-</button>
                                    <span id="waterCount">0</span>
                                    <button class="water-btn plus">+</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Reading -->
                    <div class="habit-card">
                        <div class="habit-icon">📖</div>
                        <h3>Reading</h3>
                        <div class="habit-inputs">
                            <div class="input-group">
                                <label>Minutes</label>
                                <input type="number" id="readingMinutes" min="0" placeholder="0">
                            </div>
                            <div class="input-group">
                                <label>Book/Article</label>
                                <input type="text" id="readingMaterial" placeholder="What did you read?">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="action-buttons">
                    <button id="saveHabits" class="btn btn-primary btn-lg">
                        <i class="fas fa-save"></i> Save Today's Habits
                    </button>
                    <button id="clearHabits" class="btn btn-secondary">
                        <i class="fas fa-undo"></i> Clear
                    </button>
                </div>
                <div id="saveMessage" class="save-message"></div>
            </div>

            <!-- Video Diary Tab -->
            <div class="tab-content" id="video-tab">
                <header class="page-header">
                    <h1>🎥 Video Diary</h1>
                </header>
                <div class="video-section">
                    <div class="video-controls">
                        <button id="startRecording" class="btn btn-danger">
                            <i class="fas fa-circle"></i> Start Recording
                        </button>
                        <button id="stopRecording" class="btn btn-secondary" disabled>
                            <i class="fas fa-stop"></i> Stop
                        </button>
                        <button id="saveVideo" class="btn btn-success" disabled>
                            <i class="fas fa-cloud-upload-alt"></i> Save to Drive
                        </button>
                    </div>
                    <div class="video-container">
                        <video id="preview" autoplay muted></video>
                        <video id="recordedVideo" controls style="display:none;"></video>
                    </div>
                    <div id="recordingStatus" class="recording-status"></div>
                    <div id="uploadProgress" class="progress-bar" style="display:none;">
                        <div class="progress-fill"></div>
                    </div>
                </div>
            </div>

            <!-- History Tab -->
            <div class="tab-content" id="history-tab">
                <header class="page-header">
                    <h1>📅 History</h1>
                </header>
                <div class="history-controls">
                    <div class="month-selector">
                        <button id="prevMonth" class="btn btn-secondary">
                            <i class="fas fa-chevron-left"></i>
                        </button>
                        <span id="currentMonthDisplay"></span>
                        <button id="nextMonth" class="btn btn-secondary">
                            <i class="fas fa-chevron-right"></i>
                        </button>
                    </div>
                    <button id="loadMonthHistory" class="btn btn-primary">
                        <i class="fas fa-search"></i> Load Month
                    </button>
                </div>
                <div class="calendar-view" id="calendarView"></div>
                <div class="selected-day-details" id="selectedDayDetails"></div>
            </div>

            <!-- Statistics Tab -->
            <div class="tab-content" id="statistics-tab">
                <header class="page-header">
                    <h1>📊 Statistics & Insights</h1>
                </header>
                <div class="stats-controls">
                    <select id="statsPeriod">
                        <option value="7">Last 7 days</option>
                        <option value="30">Last 30 days</option>
                        <option value="90">Last 3 months</option>
                        <option value="365">Last year</option>
                    </select>
                    <button id="loadStatistics" class="btn btn-primary">
                        <i class="fas fa-chart-line"></i> Generate Stats
                    </button>
                </div>
                <div class="stats-grid" id="statsGrid">
                    <!-- Stats will be generated here -->
                </div>
                <div class="charts-container">
                    <canvas id="habitsChart"></canvas>
                </div>
            </div>

            <!-- Daily Notes Tab -->
            <div class="tab-content" id="notes-tab">
                <header class="page-header">
                    <h1>📝 Daily Notes & Journal</h1>
                    <div class="date-display" id="notesDate"></div>
                </header>
                <div class="notes-container">
                    <div class="mood-selector">
                        <label>Today's Mood:</label>
                        <div class="mood-emojis">
                            <span class="mood" data-mood="great">😄</span>
                            <span class="mood" data-mood="good">🙂</span>
                            <span class="mood" data-mood="okay">😐</span>
                            <span class="mood" data-mood="bad">😔</span>
                            <span class="mood" data-mood="terrible">😢</span>
                        </div>
                    </div>
                    <div class="gratitude-section">
                        <h3>3 Things I'm Grateful For:</h3>
                        <textarea id="gratitude1" placeholder="1..."></textarea>
                        <textarea id="gratitude2" placeholder="2..."></textarea>
                        <textarea id="gratitude3" placeholder="3..."></textarea>
                    </div>
                    <div class="journal-section">
                        <h3>Daily Journal</h3>
                        <textarea id="journalEntry" placeholder="Write your thoughts, achievements, challenges..."></textarea>
                    </div>
                    <button id="saveNotes" class="btn btn-primary btn-lg">
                        <i class="fas fa-save"></i> Save Notes
                    </button>
                </div>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="script.js"></script>
</body>
</html>